# Stage 1: Build the Go application
FROM golang:1.20-alpine AS builder
WORKDIR /app
COPY go.mod ./
COPY main.go ./
# Compile the Go code into an executable file named 'cart-app'
RUN go build -o cart-app main.go

# Stage 2: Create the final tiny image
FROM alpine:latest
WORKDIR /app
# Copy only the compiled executable from the builder stage
COPY --from=builder /app/cart-app .

EXPOSE 8080

# Run the executable
CMD ["./cart-app"]
